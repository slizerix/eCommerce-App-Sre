{
  "uid": "shop-user-journey",
  "title": "Shop · User Journey",
  "tags": ["shop", "funnel"],
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Funnel",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Journey rates (per minute)",
      "description": "Each step of browse → cart → checkout → payment, as 5-minute rolling rates. Read the slopes top-to-bottom: any step that drops while the one above it stays flat is where conversion is leaking.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "expr": "sum(rate(signups_total[5m])) * 60",        "legendFormat": "signups/min" },
        { "refId": "B", "expr": "sum(rate(logins_total{result=\"success\"}[5m])) * 60", "legendFormat": "logins/min" },
        { "refId": "C", "expr": "sum(rate(cart_adds_total[5m])) * 60",      "legendFormat": "cart adds/min" },
        { "refId": "D", "expr": "sum(rate(checkouts_created_total{result=\"created\"}[5m])) * 60", "legendFormat": "checkouts/min" },
        { "refId": "E", "expr": "sum(rate(payment_attempts_total{result=\"succeeded\"}[5m])) * 60", "legendFormat": "payments_ok/min" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Payment success rate (5m)",
      "description": "≥ 95% is healthy. Drops below 90% in steady state usually mean the provider is degrading; correlate with payment latency p95.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "orange", "value": 0.9 },
            { "color": "green", "value": 0.95 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background" },
      "targets": [
        { "refId": "A", "expr": "sum(rate(payment_attempts_total{result=\"succeeded\"}[5m])) / clamp_min(sum(rate(payment_attempts_total[5m])), 0.0001)" }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Insufficient stock (5m)",
      "description": "Rising counter is a leading indicator of either a demand spike or stale stock — check before customers complain.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 5 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 1 },
            { "color": "red", "value": 5 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "targets": [
        { "refId": "A", "expr": "increase(insufficient_stock_total[5m])" }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Payment",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 10 },
      "collapsed": false
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Payment provider latency",
      "description": "Histogram percentiles for the outbound provider call only (not our handler). If p95 climbs while http_request_duration_seconds for /api/payment stays flat-ish, the provider is degrading independently of our service.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 11 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.5,  sum by (le) (rate(payment_duration_seconds_bucket[5m])))", "legendFormat": "p50" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum by (le) (rate(payment_duration_seconds_bucket[5m])))", "legendFormat": "p95" },
        { "refId": "C", "expr": "histogram_quantile(0.99, sum by (le) (rate(payment_duration_seconds_bucket[5m])))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 12,
      "type": "piechart",
      "title": "Payment outcomes (5m)",
      "description": "Breakdown of recent payment attempts. `succeeded` should dominate; if a decline reason is climbing, surface that on the AI summary.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 11 },
      "options": { "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] } },
      "targets": [
        { "refId": "A", "expr": "sum by (result, decline_reason) (increase(payment_attempts_total[5m]))", "legendFormat": "{{result}} {{decline_reason}}" }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "Checkout",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 },
      "collapsed": false
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Checkout outcomes (per minute)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 21 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "expr": "sum by (result) (rate(checkouts_created_total[5m])) * 60", "legendFormat": "{{result}}/min" }
      ]
    }
  ]
}
