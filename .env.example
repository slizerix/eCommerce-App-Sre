# Copy to .env (the repo's .gitignore should keep it out of git).
# Compose reads variables from .env automatically.

# Required for the AI investigator service to call OpenAI.
OPENAI_API_KEY=sk-...

# Defaults shown; uncomment to override.
# OPENAI_MODEL=gpt-4o-mini

# Crank this to make payment failures common enough to spot on the dashboard
# within seconds. Default is 0.08 (~8%).
# PAYMENT_FAILURE_RATE=0.5

# Load generator knobs.
# LOADGEN_RPS=3
# LOADGEN_ENABLED=1
